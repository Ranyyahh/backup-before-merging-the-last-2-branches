@{
    Layout = null;
    ViewBag.Title = "BizzyQCU – Enterprises";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>

    <link rel="stylesheet" href="~/Content/AdminLandingEntrep.css" />
    <link rel="stylesheet" href="~/Content/Fonts/Fonts.css" />
</head>
<body>

    <header class="navbar">
        <div class="nav-left">
            <a href="@Url.Action("LandingAdmin", "AdminPanel")" class="back-btn" title="Back">&#8592;</a>

            <div class="nav-logo">
                <div class="logo-icon"></div>
            </div>
        </div>

        <div class="search-wrap">
            <div class="search-box">
                <input type="text"
                       id="searchInput"
                       placeholder="Search an Enterprise"
                       autocomplete="off" />

                <span class="search-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                </span>
            </div>
        </div>

        <div style="width:120px;"></div>
    </header>

    <div class="page-wrapper">

        <div class="page-header">
            <div class="page-header-left">
                <h1>Enterprises</h1>
                <p>Manage and view all registered enterprise accounts</p>
            </div>

            <span class="count-badge" id="countBadge">9 Enterprises</span>
        </div>

        <div class="enterprises-grid" id="enterprisesGrid"></div>

    </div>

    <script src="~/Scripts/AdminLandingEntrep.js"></script>

</body>
</html>