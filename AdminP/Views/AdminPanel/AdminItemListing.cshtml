@{
    Layout = null;
    ViewBag.Title = "AdminUserListing – BizzyQCU";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>

    <link rel="stylesheet" href="~/Content/Fonts/Fonts.css" />
    <link rel="stylesheet" href="~/Content/AdminItemListing.css" />
</head>
<body>

    <nav class="navbar">
        <div class="nav-left">
            <button class="back-btn" onclick="history.back()">&#8249;</button>

            <div class="nav-logo">
                <div class="logo-icon"></div>
            </div>
        </div>

        <div class="search-wrap">
            <div class="search-box">
                <input type="text" placeholder="Search an Enterprise" />
            </div>
        </div>
    </nav>

    <div class="page-wrapper">
        <div class="detail-layout">

            <div class="profile-card">

                <div class="profile-avatar">
                    <img src="~/Content/Images/avatar.svg" alt="Profile Avatar" />
                </div>

                <div class="profile-name">
                    Enterprise<br />
                    Name
                </div>

                <div class="profile-meta">
                    <span class="profile-id">BQCU0110</span>
                    <button class="delete-btn" onclick="openModal()">Delete Account</button>
                </div>

                <div class="profile-stars">
                    <span class="star filled">★</span>
                    <span class="star filled">★</span>
                    <span class="star filled">★</span>
                    <span class="star filled">★</span>
                    <span class="star">★</span>
                </div>

                <div class="profile-info">
                    <p>
                        <span class="info-label">Email:</span>
                        <span class="info-value">EnterpriseQCU@gmail.com</span>
                    </p>

                    <p>
                        <span class="info-label">Status:</span>
                        <span class="status-approved">Approved</span>
                    </p>
                </div>

                <div class="profile-actions">
                    <button class="action-btn">View Reports</button>

                    <a href="@Url.Action("Index", "AdminItemListing")"
                       class="action-btn"
                       id="viewDocsBtn">
                        View Documents
                    </a>
                </div>

            </div>

            <div class="right-panel">

                <div class="product-search-wrap">
                    <div class="product-search-box">
                        <input type="text"
                               placeholder="Product"
                               id="productSearch"
                               oninput="filterProducts()" />

                        <button class="product-search-btn">🔍</button>
                    </div>
                </div>

                <div class="products-grid" id="productsGrid">

                    <div class="product-card" data-name="pasta verde">
                        <div class="product-image-wrap"></div>

                        <div class="product-info-wrap">
                            <div class="product-title">Pasta Verde</div>
                            <div class="product-detail-line">
                                <span class="detail-label">Price:</span>300PHP
                            </div>
                            <div class="product-detail-line">
                                <span class="detail-label">Description:</span>Pow Pow
                            </div>
                        </div>
                    </div>

                    <div class="product-card" data-name="donut">
                        <div class="product-image-wrap"></div>

                        <div class="product-info-wrap">
                            <div class="product-title">Donut</div>
                            <div class="product-detail-line">
                                <span class="detail-label">Price:</span>20PHP
                            </div>
                            <div class="product-detail-line">
                                <span class="detail-label">Description:</span>Kabombaclat
                            </div>
                        </div>
                    </div>

                    <div class="product-card" data-name="milk tea">
                        <div class="product-image-wrap"></div>

                        <div class="product-info-wrap">
                            <div class="product-title">Milk Tea</div>
                            <div class="product-detail-line">
                                <span class="detail-label">Price:</span>120PHP
                            </div>
                            <div class="product-detail-line">
                                <span class="detail-label">Description:</span>Wee Woo
                            </div>
                        </div>
                    </div>

                </div>

                <div class="bottom-actions">
                    <button class="approve-btn" onclick="approveItem()">Approve Item</button>
                    <button class="remove-btn" onclick="removeItem()">Remove Item</button>
                </div>

            </div>
        </div>
    </div>

    <div class="modal-backdrop" id="deleteModal">
        <div class="modal">

            <div class="modal-title">Delete Account</div>

            <div class="modal-body">
                Are you sure you want to delete
                <strong>Enterprise Name</strong>?
                This action cannot be undone.
            </div>

            <div class="modal-actions">
                <button class="modal-btn modal-cancel" onclick="closeModal()">Cancel</button>
                <button class="modal-btn modal-confirm" onclick="confirmDelete()">Delete</button>
            </div>

        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script src="~/Scripts/AdminItemListing.js"></script>

</body>
</html>