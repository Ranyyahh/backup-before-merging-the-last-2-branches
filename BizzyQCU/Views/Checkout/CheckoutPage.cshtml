@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - BizzyQCU</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/Content/checkout.css">
</head>
<body>

    <div class="navbar">
        <div class="logo">
            <a href="/"><img src="~/Images/Logo.png" alt="logo"></a>
        </div>
        <div class="divider"></div>
        <div class="nav-links">
            <a href="#">HOME</a>
            <a href="#">PRODUCTS</a>
            <a href="#">ENTERPRISES</a>
            <a href="#">ABOUT US</a>
        </div>
        <div class="account-icon">
            <img src="~/Images/5.png" alt="Account">
        </div>
    </div>

    <div class="container main-container">
        <div class="enterprise-warning mb-3">
            <i class="fas fa-info-circle"></i> You can place orders from one enterprise at a time.
            Once you start ordering from a specific enterprise, you will be limited to that enterprise until you complete your order.
            After successfully placing your order, you may then proceed to order from another enterprise.
        </div>

        <div class="checkout-card">
            <h3 class="mb-4">📋 Products Ordered</h3>
            <div id="enterpriseHeaderContainer" class="enterprise-banner" style="display: none;"></div>
            <div class="table-responsive">
                <table class="table table-cart">
                    <thead>
                        <tr>
                            <th style="width:70px"></th>
                            <th></th>
                            <th>Unit Price</th>
                            <th>Quantity</th>
                            <th>Item Subtotal</th>
                            <th style="width:60px"></th>
                        </tr>
                    </thead>
                    <tbody id="cartBody"></tbody>
                </table>
            </div>
        </div>

        <div class="checkout-card">
            <h3 class="mb-4">🚚 Delivery & Payment</h3>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Delivery Option</label>
                    <div class="d-flex justify-content-between align-items-center">
                        <span id="deliveryOptionDisplay" class="me-2">Room to Room</span>
                        <button type="button" class="btn btn-sm btn-outline-primary change-btn" data-type="delivery">CHANGE</button>
                    </div>
                    <div id="roomSpecifyContainer" class="mt-2">
                        <input type="text" id="roomSpecifyInput" class="form-control" placeholder="Specify room (e.g., IL602a, IK504)">
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Payment Method</label>
                    <div class="d-flex justify-content-between align-items-center">
                        <span id="paymentMethodDisplay" class="me-2">Cash on Delivery</span>
                        <button type="button" class="btn btn-sm btn-outline-primary change-btn" data-type="payment">CHANGE</button>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <label class="fw-bold">Note (optional)</label>
                <textarea id="orderNote" class="form-control" rows="2" placeholder="Add special instructions, delivery notes, etc."></textarea>
            </div>
        </div>

        <div class="checkout-card">
            <div class="d-flex flex-wrap justify-content-between align-items-center">
                <div>
                    <span class="fw-bold">Total Payment</span>
                    <span class="total-payment" id="totalPayment">₱0</span>
                </div>
                <div>
                    <button class="btn btn-buy-more me-3" id="buyMoreBtn"><i class="fas fa-plus-circle"></i> Buy More</button>
                    <button class="btn btn-place-order" id="placeOrderBtn"><i class="fas fa-check-circle"></i> Place Order</button>
                </div>
            </div>
        </div>
    </div>

    <footer>&copy; 2025 BizzyQCU</footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/checkout.js"></script>
</body>
</html>