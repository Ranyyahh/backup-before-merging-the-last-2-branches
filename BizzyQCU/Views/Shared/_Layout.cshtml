<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BizzyQCU</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/Content/layout.css">
    <link rel="stylesheet" href="~/Content/home_about_product_ent.css">
    <link rel="stylesheet" href="~/Content/MobileNavbar.css">
    @RenderSection("Styles", required: false)
</head>
<body>

    <div class="navbar">

        <a href="javascript:history.back()" class="mobile-back-btn">
            <img src="~/Content/Images/back-btn.png" class="back-icon" />
        </a>

        <div class="logo">
            <a href="/"><img src="~/Images/Logo.png" alt="logo"></a>
        </div>

        <div class="divider"></div>

        <div class="nav-links" id="mainNav">
            <a href="@Url.Action("Homepage", "Home")">HOME</a>
            <a href="@Url.Action("ProductList", "ProductList")">PRODUCTS</a>
            <a href="#">ENTERPRISES</a>
            <a href="@Url.Action("About", "Home")">ABOUT US</a>

            <a href="#" class="account-mobile">
                ACCOUNT
            </a>

        </div>

        <div class="right-icons">
            <div class="cart-icon">
                <a href="#"><img src="~/Images/cart-icon.png"></a>
            </div>
            <div class="account-icon account-desktop">
                <img src="~/Images/account-icon.png">
            </div>


            <button class="hamburger" id="hamburgerBtn">
                ☰
            </button>
        </div>

    </div>

    <main>
        @RenderBody()
    </main>

    <footer style="text-align:center; margin-top:2rem; padding:1rem; color:#6c757d;">
        &copy; 2025 BizzyQCU - One Enterprise at a Time
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)


        <!--FOR HAMBURGER TOGGLE-->
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const btn = document.getElementById("hamburgerBtn");
            const nav = document.getElementById("mainNav");

            btn.addEventListener("click", function () {
                nav.classList.toggle("open");
                });
            });


    </script>
</body>
</html>