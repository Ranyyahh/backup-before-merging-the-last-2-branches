@{
    ViewBag.Title = "Products";
}

<section class="screen">
    <div class="info-card">
        <div class="panel-heading">
            <h1>Products</h1>
        </div>
        <div class="panel-divider"></div>
        <div class="details-grid">
            <div class="details-row">
                <dt>Featured Product</dt>
                <dd>Classic Siomai Rice Meal</dd>
            </div>
            <div class="details-row">
                <dt>Top Category</dt>
                <dd>Rice Meals</dd>
            </div>
            <div class="details-row">
                <dt>Available Today</dt>
                <dd>12 Items</dd>
            </div>
        </div>
        <div class="panel-divider bottom-divider"></div>
        <p>This is a demo products page, so clicking `PRODUCTS` now opens its own route instead of the enterprise profile page.</p>
    </div>
</section>
