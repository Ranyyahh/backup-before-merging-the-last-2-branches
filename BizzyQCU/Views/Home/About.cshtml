@{
    ViewBag.Title = "About Us";
}

<section class="screen screen-about">
    <div class="about-panel">
        <div class="about-copy">
            <p class="about-eyebrow">About BizzyQCU</p>
            <h1>Campus enterprise tools with a cleaner workflow.</h1>
            <p>
                BizzyQCU is presented here as a student enterprise workspace where profile management,
                performance tracking, and transaction review stay in one place.
            </p>
            <div class="about-actions">
                <a class="primary-action-button" href="@Url.Action("Index", "Home")">Open Dashboard</a>
                <a class="outline-action-button compact-button" href="@Url.Action("Profile", "Home")">Manage Profile</a>
            </div>
        </div>

        <div class="about-stats">
            <div class="about-stat-card">
                <strong>120</strong>
                <span>Orders Completed</span>
            </div>
            <div class="about-stat-card">
                <strong>35</strong>
                <span>Products Listed</span>
            </div>
            <div class="about-stat-card">
                <strong>P 50,000.00</strong>
                <span>Total Sales</span>
            </div>
        </div>
    </div>
</section>
