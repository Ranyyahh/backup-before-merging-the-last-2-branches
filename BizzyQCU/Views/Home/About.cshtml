@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "About Us";
    ViewBag.BodyClass = "about-page";
}

<div class="about-wrap">

    <div class="about-hero">
        <div class="hero-inner">
            <div class="hero-badge">
                <img src="~/Content/Images/bee_logo.png" alt="BizzyQCU Bee" class="hero-bee-img" />
            </div>
            <div class="hero-text">
                <h1>ABOUT <span>US</span></h1>
                <p>Built for the student entrepreneurs of Quezon City University — a platform that gives your business the visibility, tools, and reach it deserves, right on campus.</p>
            </div>
        </div>
    </div>

    <div class="about-body">

        <div class="highlight-band">
            <div class="highlight-band-icon">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="8" y="20" width="32" height="22" rx="3" stroke="#ffde42" stroke-width="2" />
                    <path d="M16 20V16a8 8 0 0116 0v4" stroke="#ffde42" stroke-width="2" />
                    <circle cx="24" cy="31" r="3" fill="#ffde42" />
                    <path d="M24 34v4" stroke="#ffde42" stroke-width="2" stroke-linecap="round" />
                </svg>
            </div>
            <div class="highlight-band-text">
                <h2>Your enterprise, amplified.</h2>
                <p>BizzyQCU was built with one purpose in mind — to give QCU student entrepreneurs a real, working storefront that the entire campus community can access. No more word-of-mouth only. Your products and services, always open.</p>
            </div>
        </div>

        <hr class="about-divider" />

        <div>
            <div class="sec-label">Why it matters</div>
            <div class="why-cards">
                <div class="why-card">
                    <div class="why-num">01</div>
                    <h3>Instant visibility</h3>
                    <p>Your enterprise is listed and searchable by every student, faculty, and staff member on campus the moment you go live.</p>
                </div>
                <div class="why-card">
                    <div class="why-num">02</div>
                    <h3>Easy order management</h3>
                    <p>Track incoming orders, update your product listings, and manage promotions — all from a simple, dedicated dashboard.</p>
                </div>
                <div class="why-card">
                    <div class="why-num">03</div>
                    <h3>Flexible payments</h3>
                    <p>Accept online payments or on-campus settlement methods, giving your customers options and your business more sales.</p>
                </div>
            </div>
        </div>

        <hr class="about-divider" />

        <div>
            <div class="sec-label">Getting started</div>
            <div class="sec-title">How student entrepreneurs join</div>
            <div class="steps">
                <div class="step">
                    <div class="step-dot">
                        <svg viewBox="0 0 18 18" fill="none">
                            <path d="M4 9h10M9 4v10" stroke="#ffde42" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </div>
                    <div class="step-body">
                        <h3>Register your enterprise</h3>
                        <p>Sign up and submit your student enterprise details. Once verified, your store goes live on the BizzyQCU marketplace.</p>
                    </div>
                </div>
                <div class="step">
                    <div class="step-dot">
                        <svg viewBox="0 0 18 18" fill="none">
                            <rect x="3" y="4" width="12" height="10" rx="2" stroke="#ffde42" stroke-width="1.8" />
                            <path d="M6 8h6M6 11h4" stroke="#ffde42" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </div>
                    <div class="step-body">
                        <h3>Add your products or services</h3>
                        <p>Upload photos, set prices, write descriptions, and organize your catalog exactly the way you want it presented.</p>
                    </div>
                </div>
                <div class="step">
                    <div class="step-dot">
                        <svg viewBox="0 0 18 18" fill="none">
                            <circle cx="6" cy="14" r="1.5" fill="#ffde42" />
                            <circle cx="12" cy="14" r="1.5" fill="#ffde42" />
                            <path d="M2 3h2l2 7h6l2-5H5" stroke="#ffde42" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <div class="step-body">
                        <h3>Receive and fulfill orders</h3>
                        <p>Get notified of new orders in real time. Manage fulfillment and keep your customers updated every step of the way.</p>
                    </div>
                </div>
                <div class="step">
                    <div class="step-dot">
                        <svg viewBox="0 0 18 18" fill="none">
                            <path d="M4 10l3 3 7-7" stroke="#ffde42" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <div class="step-body">
                        <h3>Grow your business</h3>
                        <p>Use promotions, track your top-selling items, and build a loyal customer base within the QCU community.</p>
                    </div>
                </div>
            </div>
        </div>

        <hr class="about-divider" />

        <div>
            <div class="sec-label">Our direction</div>
            <div class="mv-row">
                <div class="mv-card m">
                    <h3>Mission</h3>
                    <p>To empower QCU student entrepreneurs with a centralized digital platform that makes running a campus business accessible, visible, and sustainable — so every enterprise has a real chance to thrive.</p>
                </div>
                <div class="mv-card v">
                    <h3>Vision</h3>
                    <p>A QCU campus where student-run businesses are the heartbeat of campus life — and every entrepreneur has the tools, reach, and support to turn their ideas into a lasting enterprise.</p>
                </div>
            </div>
        </div>

        <hr class="about-divider" />

        <div class="feedback-box">
            <div class="sec-label">Feedback</div>
            <div class="sec-title">Send us your thoughts</div>
            <p class="sec-text">Are you a student entrepreneur or a customer? We want to hear from you. Your feedback shapes how BizzyQCU grows.</p>

            <div class="fb-form">

                <div class="fb-section-label">Your details</div>
                <div class="fb-row">
                    <div class="fb-group">
                        <label for="fb-email">Email</label>
                        <input type="email" placeholder="your@email.com" id="fb-email" />
                    </div>
                    <div class="fb-group">
                        <label for="fb-contact">Contact Number</label>
                        <input type="tel" placeholder="+63 9XX XXX XXXX" id="fb-contact" />
                    </div>
                </div>

                <hr class="fb-divider" />
                <div class="fb-section-label">About your feedback</div>
                <div class="fb-row">
                    <div class="fb-group">
                        <label for="fb-role">I am a</label>
                        <select id="fb-role">
                            <option>Entrepreneur student</option>
                            <option>Buyer</option>
                        </select>
                    </div>
                    <div class="fb-group">
                        <label for="fb-cat">Category</label>
                        <select id="fb-cat">
                            <option>General feedback</option>
                            <option>Bug / issue report</option>
                            <option>Feature suggestion</option>
                            <option>Enterprise concern</option>
                            <option>Other</option>
                        </select>
                    </div>
                </div>

                <div class="fb-group">
                    <label for="fb-msg">Message</label>
                    <textarea placeholder="Tell us what you think — what's working, what could be better, or anything you'd like us to know." id="fb-msg"></textarea>
                </div>

                <div class="fb-group fb-group--centered">
                    <label>Rate your experience</label>
                    <div class="stars" id="stars">
                        <button class="star" data-v="1">&#9733;</button>
                        <button class="star" data-v="2">&#9733;</button>
                        <button class="star" data-v="3">&#9733;</button>
                        <button class="star" data-v="4">&#9733;</button>
                        <button class="star" data-v="5">&#9733;</button>
                    </div>
                </div>

                <hr class="fb-divider" />
                <div class="fb-footer">
                    <button class="submit-btn" id="sub-btn">Submit feedback</button>
                    <div class="ok-msg" id="ok-msg">Thank you for your feedback! It helps us build a better platform for QCU student entrepreneurs.</div>
                </div>

            </div>
        </div>

    </div>
</div>

@section scripts {
    <script>
        (function () {
            var rating = 0;
            var stars = document.querySelectorAll('.star');

            stars.forEach(function (s) {
                s.addEventListener('mouseenter', function () {
                    var v = +s.dataset.v;
                    stars.forEach(function (x) { x.classList.toggle('on', +x.dataset.v <= v); });
                });
                s.addEventListener('mouseleave', function () {
                    stars.forEach(function (x) { x.classList.toggle('on', +x.dataset.v <= rating); });
                });
                s.addEventListener('click', function () {
                    rating = +s.dataset.v;
                    stars.forEach(function (x) { x.classList.toggle('on', +x.dataset.v <= rating); });
                });
            });

            document.getElementById('sub-btn').addEventListener('click', function () {
                var email = document.getElementById('fb-email').value.trim();
                var msg = document.getElementById('fb-msg').value.trim();
                if (!email || !msg) {
                    alert('Please fill in at least your email and message.');
                    return;
                }
                document.getElementById('ok-msg').style.display = 'block';
                ['fb-email', 'fb-contact', 'fb-msg'].forEach(function (id) {
                    var el = document.getElementById(id);
                    if (el) el.value = '';
                });
                document.getElementById('fb-role').value = '';
                document.getElementById('fb-cat').value = '';
                rating = 0;
                stars.forEach(function (x) { x.classList.remove('on'); });
                setTimeout(function () {
                    document.getElementById('ok-msg').style.display = 'none';
                }, 5000);
            });
        })();
    </script>
}
