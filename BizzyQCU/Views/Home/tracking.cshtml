@{
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Live Status | Campus Eats</title>
    <link rel="stylesheet" href="~/Content/trackingstyle.css" />
</head>
<body>
    <header class="glass-header">
        <div class="header-left">
            <button class="back-btn" onclick="window.location.href = '@Url.Action("Index", "Home")'">
                <svg viewBox="0 0 24 24"
                     style="
              width: 18px;
              height: 18px;
              fill: none;
              stroke: currentColor;
              stroke-width: 3;
            ">
                    <path d="M15 18l-6-6 6-6" />
                </svg>
            </button>
        </div>

        <div class="header-center">
            <img src="~/Content/images/bizzyqcu logo.png" alt="BizzyQCU Logo" class="main-logo" />
        </div>

        <div class="header-right">
            <button class="menu-btn">
                <div class="hamburger-line"></div>
                <div class="hamburger-line"></div>
                <div class="hamburger-line"></div>
            </button>
        </div>
    </header>

    <section class="top-status-bar">
        <div class="progress-info">
            <div class="status-icon-main pulse">🍳</div>
            <div style="flex: 1">
                <strong style="font-size: 18px; display: block">Preparing Order</strong>
                <span style="font-size: 12px; color: var(--text-muted)">ETA: 10:55 AM</span>
            </div>
            <div class="eta-bubble">
                <span class="number">8</span>
                <small style="font-size: 8px; font-weight: 800">MINS</small>
            </div>
        </div>

        <div class="progress-track">
            <div class="progress-fill" style="width: 45%"></div>
            <div class="check-node done" style="left: 0%"></div>
            <div class="check-node active" style="left: 45%"></div>
            <div class="check-node" style="left: 100%"></div>
        </div>
        <div class="order-status-id-container">
            <h2 class="order-id-main">Order #QCU-9821</h2>
            <span class="live-status-subtext">LIVE STATUS</span>
        </div>
    </section>

    <main style="padding: 20px">
        <button class="history-center-btn" onclick="window.location.href = '@Url.Action("history", "Home")'">
            <svg viewBox="0 0 24 24"
                 style="
            width: 20px;
            height: 20px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.5;
          ">
                <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Check Previous Orders
        </button>

        <div class="info-pill">
            <div class="info-label">
                <svg viewBox="0 0 24 24"
                     style="
              width: 12px;
              height: 12px;
              fill: none;
              stroke: currentColor;
              stroke-width: 3;
            ">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                    <circle cx="12" cy="10" r="3" />
                </svg>
                Your Location
            </div>
            <div class="info-value">Room IL603</div>
            <div class="note-box" style="margin-top: 10px">
                <strong>Note:</strong> "Bring change for 100 pesos"
            </div>
        </div>

        <div style="
          font-size: 11px;
          font-weight: 800;
          text-transform: uppercase;
          margin-bottom: 10px;
          color: lightgray;
        ">
            Order Details
        </div>

        <div class="order-details-card">
            <div class="detail-item">
                <span>1x Special Siomai Rice</span>
                <span>₱55.00</span>
            </div>
            <div class="detail-item">
                <span>1x Iced Coffee (Small)</span>
                <span>₱30.00</span>
            </div>
            <div class="detail-total">
                <span>Total Paid</span>
                <span>₱85.00</span>
            </div>
        </div>

        <div style="
          font-size: 11px;
          font-weight: 800;
          text-transform: uppercase;
          color: lightgray;
          margin-bottom: 10px;
        ">
            Your Courier
        </div>

        <div class="courier-card-static">
            <div class="courier-avatar">JT</div>
            <div style="flex: 1">
                <h4 style="margin: 0">Jediael Tangonan</h4>
                <p style="margin: 2px 0; font-size: 11px; color: var(--text-muted)">
                    BSIT-2D • Student Courier
                </p>
            </div>
            <div style="display: flex; gap: 8px">
                <button class="c-btn-filled">💬</button>
                <button class="c-btn-filled"
                        style="background: var(--primary-yellow)">
                    📞
                </button>
            </div>
        </div>
    </main>
</body>
</html>
